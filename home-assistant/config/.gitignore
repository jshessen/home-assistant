# Home Assistant Configuration .gitignore

# ============================================================================
# Secrets & Sensitive Data
# ============================================================================
secrets.yaml
secrets/
*.key
*.pem
*.crt

# ============================================================================
# Runtime Data & Logs (data/ directory)
# ============================================================================
# Keep directory structure but ignore generated files
data/**/*.log
data/**/*.json
data/**/*.har
data/**/*.tmp
data/**/*.cache

# Alternative: Uncomment to exclude all data directory contents
# data/*
# !data/README.md
# !data/**/.gitkeep

# ============================================================================
# Home Assistant Internal Storage
# ============================================================================
.storage/
.cloud/
.google.token

# ============================================================================
# Database & Recorder
# ============================================================================
home-assistant_v2.db
home-assistant_v2.db-shm
home-assistant_v2.db-wal
*.db-journal

# ============================================================================
# Logs
# ============================================================================
*.log
*.log.*
OZW_Log.txt

# ============================================================================
# Dependencies & Cache
# ============================================================================
deps/
tts/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# Custom Components (Optional)
# ============================================================================
# Uncomment to ignore HACS-installed components (they can be reinstalled)
# custom_components/hacs/
# custom_components/spook/
# custom_components/alarmo/

# ============================================================================
# Integration Auto-Generated Files
# ============================================================================
harmony_*.conf

# ============================================================================
# Temporary & Backup Files
# ============================================================================
*.bak
*.backup
*.tmp
*.old

# ============================================================================
# Documentation (Managed)
# ============================================================================
# These ARE tracked - custom documentation is part of config
# docs/ - TRACKED
# data/README.md - TRACKED
# README.md - TRACKED
