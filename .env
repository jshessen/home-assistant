ALL_SERVICES=home-assistant zwave-js-ui mqtt zigbee2mqtt
CLEAN=1
COMPOSE_ALL_FILES=-f docker-compose.yml -f docker-compose.zwave.yml -f docker-compose.mqtt.yml -f docker-compose.zigbee.yml
COMPOSE_HACS=-f docker-compose.yml -f docker-compose.zwave.yml
COMPOSE_HASS=-f docker-compose.yml
COMPOSE_MQTT=-f docker-compose.mqtt.yml
COMPOSE_PROJECT_NAME=home-assistant
COMPOSE_ZIGBEE=-f docker-compose.zigbee.yml
COMPOSE_ZWAVE=-f docker-compose.zwave.yml
CONFIG_DIR=./config.d
CURDIR=/opt/docker/home-assistant
DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
f=./config.d/hacs.env
GNUMAKEFLAGS=
HACS_PORT=8123
HACS_SERVICE=home-assistant zwave-js-ui
HACS_TAG=latest
HASS_PORT=8123
HASS_SERVICE=homeassistant
HOME=/home/jshessen
LANG=en_GB.UTF-8
LOGNAME=jshessen
LS_COLORS=rs=0:di=01;34:ln=01;36:mh=00:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:mi=00:su=37;41:sg=30;43:ca=00:tw=30;42:ow=34;42:st=37;44:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arc=01;31:*.arj=01;31:*.taz=01;31:*.lha=01;31:*.lz4=01;31:*.lzh=01;31:*.lzma=01;31:*.tlz=01;31:*.txz=01;31:*.tzo=01;31:*.t7z=01;31:*.zip=01;31:*.z=01;31:*.dz=01;31:*.gz=01;31:*.lrz=01;31:*.lz=01;31:*.lzo=01;31:*.xz=01;31:*.zst=01;31:*.tzst=01;31:*.bz2=01;31:*.bz=01;31:*.tbz=01;31:*.tbz2=01;31:*.tz=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.war=01;31:*.ear=01;31:*.sar=01;31:*.rar=01;31:*.alz=01;31:*.ace=01;31:*.zoo=01;31:*.cpio=01;31:*.7z=01;31:*.rz=01;31:*.cab=01;31:*.wim=01;31:*.swm=01;31:*.dwm=01;31:*.esd=01;31:*.avif=01;35:*.jpg=01;35:*.jpeg=01;35:*.mjpg=01;35:*.mjpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.svg=01;35:*.svgz=01;35:*.mng=01;35:*.pcx=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.m2v=01;35:*.mkv=01;35:*.webm=01;35:*.webp=01;35:*.ogm=01;35:*.mp4=01;35:*.m4v=01;35:*.mp4v=01;35:*.vob=01;35:*.qt=01;35:*.nuv=01;35:*.wmv=01;35:*.asf=01;35:*.rm=01;35:*.rmvb=01;35:*.flc=01;35:*.avi=01;35:*.fli=01;35:*.flv=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.yuv=01;35:*.cgm=01;35:*.emf=01;35:*.ogv=01;35:*.ogx=01;35:*.aac=00;36:*.au=00;36:*.flac=00;36:*.m4a=00;36:*.mid=00;36:*.midi=00;36:*.mka=00;36:*.mp3=00;36:*.mpc=00;36:*.ogg=00;36:*.ra=00;36:*.wav=00;36:*.oga=00;36:*.opus=00;36:*.spx=00;36:*.xspf=00;36:*~=00;90:*
MAKEFILE_LIST=Makefile
MAKEFLAGS=
MAKELEVEL=1
MAKE_TERMERR=/dev/pts/0
MAKE_TERMOUT=/dev/pts/0
MFLAGS=
MOTD_SHOWN=pam
MQTTADMIN=hacs
MQTTADMINPW=***REDACTED***
MQTT_PORT=1883
MQTT_QUIC_PORT=14567
MQTT_SERVICE=mqtt
MQTT_SSL_PORT=8883
MQTT_TAG=latest
MQTT_WS_PORT=443
NO_AT_BRIDGE=1
OLDPWD=/opt/docker/home-assistant/secrets
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/games:/usr/games
POSTGRES_DB=homeassistant
POSTGRES_USER=homeassistant
PWD=/opt/docker/home-assistant
SHELL=/bin/bash
SHLVL=9
SOCKET_PROXY_PORT=2375
SSH_CLIENT=192.168.1.21 41372 22
SSH_CONNECTION=192.168.1.21 41372 192.168.1.33 22
SSH_TTY=/dev/pts/0
TERM=xterm-256color
TEXTDOMAIN=Linux-PAM
TZ=America/Chicago
USER=jshessen
_=/usr/bin/env
XDG_RUNTIME_DIR=/run/user/1000
XDG_SESSION_CLASS=user
XDG_SESSION_ID=64
XDG_SESSION_TYPE=tty
ZIGBEE2MQTT_PORT=8080
ZIGBEE2MQTT_TAG=latest
ZIGBEE_SERVICE=zigbee2mqtt
ZWAVE_JS_UI_PORT=8091
ZWAVE_JS_UI_PORT_WS=3000
ZWAVE_JS_UI_TAG=latest
ZWAVE_SERVICE=zwave-js-ui
