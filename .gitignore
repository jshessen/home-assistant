# Home Assistant secrets
secrets.yaml
known_devices.yaml
home-assistant.log
home-assistant_v2.db
*.db-journal
*.pid
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# ─── Home Assistant runtime artifacts ────────────────────────────────────────
# Never commit HA runtime state — these are regenerated at startup
home-assistant/config/.storage/
home-assistant/config/.HA_VERSION
home-assistant/config/.ha_run.lock
home-assistant/config/home-assistant.log
home-assistant/config/home-assistant.log.*
home-assistant/config/home-assistant_v2.db
home-assistant/config/home-assistant_v2.db.backup
home-assistant/config/deps/
home-assistant/config/backups/
home-assistant/config/tts/
home-assistant/config/.cloud/
home-assistant/config/OZW_Log.txt

# ─── Home Assistant: data/ directory ─────────────────────────────────────────
# Runtime-generated files — only README.md is ours
home-assistant/config/data/**
!home-assistant/config/data/README.md

# ─── Home Assistant: www/ frontend resources ─────────────────────────────────
# HACS-installed frontend cards and resources, not authored here
home-assistant/config/www/

# ─── External repos (not owned by this project) ──────────────────────────────
# These have their own .git — never let git sweep them up
keymaster-github/
pyonwater-github/

# ─── Docker secrets ──────────────────────────────────────────────────────────
# Secret files are bind-mounted by Docker; never store in git
secrets/

# ─── Log files ───────────────────────────────────────────────────────────────
*.log
*.log.*
*.log.fault
*.log.grep.txt
zwave/logs/

# ─── Database files ──────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db.backup

# ─── Docker runtime state ────────────────────────────────────────────────────
postgres/data/
mosquitto/data/
mosquitto/logs/
mosquitto/config/password.txt
zigbee2mqtt/data/log/
zigbee2mqtt/data/configuration_backup*.yaml
zigbee2mqtt/data/coordinator_backup.json
zigbee2mqtt/data/state.json

# ─── Python artifacts ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
.mypy_cache/

# ─── VS Code user-local state ────────────────────────────────────────────────
# Keep .code-workspace (shared config); ignore user-local settings
.vscode/

# ─── NOTE: .squad/ is intentional team state — do NOT add it here ─────────────

# ─── config.d: files with credentials ────────────────────────────────────────
# mqtt.env contains MQTTADMINPW plaintext — use secrets/ dir for credentials
# Password also at secrets/mqtt_admin_password (already gitignored via secrets/)
config.d/mqtt.env

# ─── Root .env — contains plaintext credentials (MQTTADMINPW etc.) ───────────
.env

# ─── Home Assistant: HACS-managed components ─────────────────────────────────
# custom_components/ is installed by HACS — not authored in this repo
# Source for any custom component lives in its own repo (e.g. keymaster-github/)
home-assistant/config/custom_components/

# ─── Home Assistant: community blueprints ────────────────────────────────────
# Blueprints installed from the community — re-importable, not ours to own
# Only blueprints/automation/jshessen/ is custom-authored and tracked
home-assistant/config/blueprints/automation/adchevrier/
home-assistant/config/blueprints/automation/aderusha/
home-assistant/config/blueprints/automation/alexdelprete/
home-assistant/config/blueprints/automation/Blackshome/
home-assistant/config/blueprints/automation/blich/
home-assistant/config/blueprints/automation/ha-blueprints/
home-assistant/config/blueprints/automation/homeassistant/
home-assistant/config/blueprints/automation/hvorragend/
home-assistant/config/blueprints/automation/jerelabs/
home-assistant/config/blueprints/script/
home-assistant/config/blueprints/template/
# Backup files in jshessen blueprints dir
home-assistant/config/blueprints/automation/jshessen/*.OLD_BACKUP*

# ─── Home Assistant: runtime cache ───────────────────────────────────────────
# .cache/ holds downloaded brand icons and similar runtime artifacts
home-assistant/config/.cache/

# ─── Z-Wave JS UI: runtime state ─────────────────────────────────────────────
# .config-db/  — device configuration database, downloaded at runtime
# plugins/sessions/snippets/ — runtime-managed directories
# nodes.json   — live Z-Wave network topology (regenerated at runtime)
# users.json   — user accounts with scrypt password hashes (SECURITY)
# *.pem        — SSL certificate + private key (SECURITY)
# *.jsonl      — Z-Wave network state/values (d5eac29d.jsonl etc.)
zwave/.config-db/
zwave/plugins/
zwave/sessions/
zwave/snippets/
zwave/nodes.json
zwave/users.json
zwave/*.pem
zwave/*.jsonl
